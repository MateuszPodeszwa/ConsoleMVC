<Project>

    <!-- Auto-include .cvw view files as AdditionalFiles for the source generator -->
    <ItemGroup>
        <AdditionalFiles Include="Views/**/*.cvw" />
    </ItemGroup>

    <!-- Expose RootNamespace to the source generator so it can use the consumer's namespace -->
    <ItemGroup>
        <CompilerVisibleProperty Include="RootNamespace" />
    </ItemGroup>

    <!-- IDE (Visual Studio / Rider) fast up-to-date check: treat .cvw edits as build inputs -->
    <ItemGroup>
        <UpToDateCheckInput Include="Views/**/*.cvw" />
    </ItemGroup>

</Project>
