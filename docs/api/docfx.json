{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/ConsoleMVC/ConsoleMVC.csproj",
            "src/ConsoleMVC.Generators/ConsoleMVC.Generators.csproj"
          ],
          "src": "../../"
        }
      ],
      "dest": "_metadata"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**.yml",
          "index.md"
        ],
        "src": "_metadata",
        "dest": "."
      },
      {
        "files": [
          "*.md",
          "toc.yml"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "ConsoleMVC API Reference",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/MateuszPodeszwa/ConsoleMVC",
        "branch": "main"
      }
    },
    "postProcessors": [
      "ExtractSearchIndex"
    ]
  }
}
